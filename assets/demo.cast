[2.595464, "o", "\u001b[32m╭─\u001b[0m\u001b[32m──────────────────────\u001b[0m\u001b[32m Demo Complete \u001b[0m\u001b[32m──────────────────────\u001b[0m\u001b[32m─╮\u001b[0m\r\n\u001b[32m│\u001b[0m \u001b[1;32mAll tests passed!\u001b[0m                                           \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                             \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m What you just saw:                                          \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • A Python agent wrapped with \u001b[1mGenericAdapter\u001b[0m              \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • 8 tests running at the \u001b[1mmock\u001b[0m layer (free, deterministic) \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   • Full \u001b[1mAgentRun\u001b[0m traces for each execution                 \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                             \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m Next steps:                                                 \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   \u001b[2mcheckagent init\u001b[0m     — scaffold your own test project      \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   \u001b[2mcheckagent run\u001b[0m      — run your agent tests                \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   \u001b[2mpytest -v\u001b[0m           — use pytest directly                 \u001b[32m│\u001b[0m\r\n\u001b[32m╰─────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
